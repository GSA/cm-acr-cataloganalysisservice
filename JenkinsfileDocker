pipeline {
    agent any
    environment {
        imagename ="acr/cataloganalysisservice"
        registry='556904013717.dkr.ecr.us-east-1.amazonaws.com'


    }
    stages {
        stage('Build Docker image') {
            steps {
               sh """aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin  752281881774.dkr.ecr.us-east-1.amazonaws.com
               script {
                  if (env.ENV_NAME == "vpc") {
                      docker build --no-cache -t acr/cataloganalysisservice:$GIT_COMMIT -f Dockerfile-vpc ."""
                  }
                  if (env.ENV_NAME != "vpc") {
                      docker build --no-cache -t acr/cataloganalysisservice:$GIT_COMMIT -f Dockerfile ."""
                  }
               }
            }
        }
        stage('Tagging docker image') {
            steps {
               sh "docker tag acr/cataloganalysisservice:$GIT_COMMIT 556904013717.dkr.ecr.us-east-1.amazonaws.com/acr/cataloganalysisservice:$GIT_COMMIT"
            }
        }
        stage('Pushing to ECR') {
            steps {
                sh "docker push 556904013717.dkr.ecr.us-east-1.amazonaws.com/acr/cataloganalysisservice:$GIT_COMMIT"
            }
        }
        stage('Update flux') {
            steps {
              build job: 'flux-update', parameters: [[$class: 'StringParameterValue', name: 'FLUX_HASH', value: env.GIT_COMMIT], [$class: 'StringParameterValue', name: 'FLUX_FILENAME', value: 'cataloganalysisservice.yaml']]
            }
        }

    }
}

